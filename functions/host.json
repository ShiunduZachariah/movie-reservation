{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true
      }
    }
  },
  "extensions": {
    "queues": {
      "maxPollingInterval": "00:00:05",
      "visibilityTimeout": "00:01:00",
      "batchSize": 1,
      "maxDequeueCount": 3,
      "newBatchThreshold": 0
    }
  }
}

